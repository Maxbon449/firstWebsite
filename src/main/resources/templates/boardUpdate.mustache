<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>게시글 수정</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f8f9fa; }
        .update-container { max-width: 800px; margin-top: 50px; background: white; padding: 40px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        textarea { resize: none; height: 350px; }
    </style>
</head>
<body>

<div class="container update-container">
    <h3 class="mb-4 fw-bold text-center">✏️ 게시글 수정하기</h3>
    <hr>

    {{#board}}
        <form action="/board/update/{{id}}" method="post" class="needs-validation" novalidate>

            <div class="mb-3">
                <label for="boardRole" class="form-label fw-bold">말머리</label>
                <select class="form-select" id="boardRole" name="boardRole" required>
                    <option value="RECOMMEND">추천 게시판</option>
                    <option value="GATHER">모집 게시판</option>
                </select>
                <div class="invalid-feedback">말머리를 선택해주세요.</div>
            </div>

            <div class="mb-3">
                <label for="title" class="form-label fw-bold">제목</label>
                <input type="text" class="form-control" id="title" name="title"
                       value="{{title}}" required>
                <div class="invalid-feedback">제목은 비워둘 수 없습니다.</div>
            </div>

            <div class="mb-4">
                <label for="content" class="form-label fw-bold">내용</label>
                <textarea class="form-control" id="content" name="content" required>{{content}}</textarea>
                <div class="invalid-feedback">내용을 입력해주세요.</div>
            </div>

            <hr>

            <div class="d-flex justify-content-center gap-3">
                <a href="/board" class="btn btn-secondary px-4">이전으로</a>
                <button type="submit" class="btn btn-warning text-white px-4">수정하기</button>
            </div>
        </form>

        <script>
            // mustache 변수 boardRole을 자바스크립트가 인식하도록 처리
            document.getElementById('boardRole').value = "{{boardRole}}";
        </script>
    {{/board}}
</div>

<script>
    // 부트스트랩 유효성 검사 스크립트 (빈 칸 방지)
    (function () {
        'use strict'
        var forms = document.querySelectorAll('.needs-validation')
        Array.prototype.slice.call(forms).forEach(function (form) {
            form.addEventListener('submit', function (event) {
                if (!form.checkValidity()) {
                    event.preventDefault()
                    event.stopPropagation()
                }
                form.classList.add('was-validated')
            }, false)
        })
    })()
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>